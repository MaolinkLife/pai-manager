# =======================
# FRONTEND (Angular)
# =======================

# compiled output
frontend/dist/
frontend/tmp/
frontend/out-tsc/
# Only exists if Bazel was run
frontend/bazel-out/

# dependencies
frontend/node_modules/

# profiling files
frontend/chrome-profiler-events*.json

# misc
frontend/.sass-cache
frontend/connect.lock
frontend/coverage/
frontend/libpeerconnection.log
frontend/npm-debug.log
frontend/yarn-error.log
frontend/testem.log
frontend/typings/

# Angular project IDE configs
frontend/.idea/
frontend/.project
frontend/.classpath
frontend/.c9/
frontend/*.launch
frontend/.settings/
frontend/*.sublime-workspace

# VSCode
frontend/.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
frontend/.history/
frontend/.angular/

# =======================
# BACKEND (Python)
# =======================

# Byte-compiled / optimized / DLL files
backend/__pycache__/
backend/**/__pycache__/
backend/*.py[cod]
backend/*.so

# Virtual environment
backend/venv/

# Logs and caches
backend/*.log
backend/.mypy_cache/
backend/.pytest_cache/
backend/.cache/

# IDEs
.idea/
.vscode/

# =======================
# SYSTEM FILES
# =======================

.DS_Store
Thumbs.db
*.log
*.swp
*.tmp

# =======================
# CHARACTER CARDS
# =======================

# Ignore all personal cards
backend/config/characters/*

# But we leave the default
!backend/config/characters/default.yaml

# Config.json — created automatically, do not push
backend/config/config.json
backend/config/lorebook.json
backend/config/generation_presets.json

backend/storage/history/*
backend/storage/files/*
backend/storage/database/*
backend/storage/vector_store
backend/storage/models/*

backend/temp/audio/*
backend/temp/logs/*
backend/temp/output/*
backend/temp/vision/*
backend/temp/voice/*

backend/logs/
backend/telegram/data/
backend/data/*.db
backend/data/telegram/*.session
backend/data/telegram/*.session-journal
backend/**/z-waif.session
backend/**/z-waif.session-journal
